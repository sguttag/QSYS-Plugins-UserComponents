-- Eprad eCNA Cinema Automation Interface (CAI) Plugin
-- Protocol: CAI ASCII over TCP
-- Reference: eCNA Operation and Installation Manual, Section 6

PluginInfo = {
  Name         = "Eprad~eCNA v1.0.1",
  Manufacturer = "STG",
  Version      = "1.0.1.53",
  Id           = "8cd1a925-90ba-4640-8de9-886632d1e242",
  Description  = "Controls the Eprad eCNA Cinema Automation system via the CAI ASCII TCP interface.",
  ShowDebug    = true,
  Author       = "Based on HTTP script 1.3.1 by Jay Wyatt and Steve Guttag."
}

function GetColor(props)
  return { 72, 147, 217 }
end

-- ============================================================
-- PAGE LIST: builds the list of visible tabs based on properties
-- Debug tab visibility controlled by Show_Debug property
-- ============================================================
local function buildPageList(props)
  local pages = {"Setup", "Outputs", "Inputs"}
  local numMacros  = props["Num_Macros"]  and props["Num_Macros"].Value  or 50
  local numRDI     = props["Num_RDI"]     and props["Num_RDI"].Value     or 5
  local showDebug  = props["Show Debug Tab"]  and props["Show Debug Tab"].Value  or false
  if numMacros > 0 then table.insert(pages, "Macros") end
  if numRDI    > 0 then table.insert(pages, "RDI")    end
  table.insert(pages, "Program")
  if showDebug    then table.insert(pages, "Debug")   end
  return pages
end

-- ============================================================
-- CONTROLS DEFINITION
-- All plugin controls are declared here with type, pin style, etc.
-- ============================================================
function GetControls(props)
  local ctrls = {}
  local numMacros = props["Num_Macros"] and props["Num_Macros"].Value or 50
  local numRDI    = props["Num_RDI"]    and props["Num_RDI"].Value    or 5

  -- Setup / Connection
  table.insert(ctrls, { Name="IP_ADDRESS",       ControlType="Text",   Count=1, UserPin=true,  PinStyle="Input",  Description="eCNA IP Address" })
  table.insert(ctrls, { Name="TCP_PORT",         ControlType="Text",   Count=1, UserPin=true,  PinStyle="Input",  Description="TCP Port (default 13002)" })
  table.insert(ctrls, {
    Name="Status", ControlType="Indicator", IndicatorType="Status",
    PinStyle="Output", UserPin=true, Count=1
  })
  table.insert(ctrls, {
    Name="Status_LED", ControlType="Indicator", IndicatorType="Status",
    PinStyle="Output", UserPin=true, Count=1
  })
  table.insert(ctrls, { Name="Reconnect",        ControlType="Button", Count=1, UserPin=true,  PinStyle="Input",  ButtonType="Momentary", Description="Force reconnect" })
  table.insert(ctrls, { Name="Model",            ControlType="Text",   Count=1, UserPin=true,  PinStyle="Output", Description="Device model (from RID)" })
  table.insert(ctrls, { Name="Firmware_Version", ControlType="Text",   Count=1, UserPin=true,  PinStyle="Output", Description="Firmware version (from RID)" })

  -- Program state (all text outputs from RST polling)
  table.insert(ctrls, { Name="Control_State",  ControlType="Text",  Count=1, UserPin=true, PinStyle="Output", Description="IDL=Idle / RUN=Running" })
  table.insert(ctrls, { Name="Stopped_State",  ControlType="Text",  Count=1, UserPin=true, PinStyle="Output", Description="OK / STP / FLT / FIR" })
  table.insert(ctrls, { Name="Cue_Number",     ControlType="Text",  Count=1, UserPin=true, PinStyle="Output", Description="Current cue number" })
  table.insert(ctrls, { Name="Program_Number", ControlType="Text",  Count=1, UserPin=true, PinStyle="Output", Description="Active program number" })
  table.insert(ctrls, { Name="Segment_Name",   ControlType="Text",  Count=1, UserPin=true, PinStyle="Output", Description="Current segment name" })
  table.insert(ctrls, { Name="Segment_Index",  ControlType="Text",  Count=1, UserPin=true, PinStyle="Output", Description="Current segment index" })
  table.insert(ctrls, { Name="CAI_CMD_Access", ControlType="Text",  Count=1, UserPin=true, PinStyle="Output", Description="OK=Full access / BLK=Blocked" })

  -- EVT Transport Commands (Trigger type - fire on press, no toggle state)
  table.insert(ctrls, { Name="Cmd_Start",        ControlType="Button", Count=1, UserPin=true, PinStyle="Input", ButtonType="Trigger",   Description="Start/Resume (EVT STA)" })
  table.insert(ctrls, { Name="Cmd_Stop",         ControlType="Button", Count=1, UserPin=true, PinStyle="Input", ButtonType="Trigger",   Description="Stop (EVT STP)" })
  table.insert(ctrls, { Name="Cmd_Cue",          ControlType="Button", Count=1, UserPin=true, PinStyle="Input", ButtonType="Trigger",   Description="Cue (EVT CUE)" })
  table.insert(ctrls, { Name="Cmd_Abort",        ControlType="Button", Count=1, UserPin=true, PinStyle="Input", ButtonType="Trigger",   Description="Abort (EVT ABT)" })
  table.insert(ctrls, { Name="Cmd_Fault",        ControlType="Button", Count=1, UserPin=true, PinStyle="Input", ButtonType="Trigger",   Description="Set Fault (EVT FLT)" })
  table.insert(ctrls, { Name="Cmd_Clear_Fault",  ControlType="Button", Count=1, UserPin=true, PinStyle="Input", ButtonType="Trigger",   Description="Clear Fault (EVT CLR)" })
  table.insert(ctrls, { Name="Cmd_Reset",        ControlType="Button", Count=1, UserPin=true, PinStyle="Input", ButtonType="Trigger",   Description="Reset Fault (EVT RES)" })
  table.insert(ctrls, { Name="Cmd_Cancel_Alarm", ControlType="Button", Count=1, UserPin=true, PinStyle="Input", ButtonType="Trigger",   Description="Cancel Alarm (EVT CNL)" })

  -- Program selection (ComboBox for program number, Trigger for execute)
  table.insert(ctrls, { Name="Set_Program",     ControlType="Text",   Count=1, UserPin=true, PinStyle="Input",  Description="Program number to set" })
  table.insert(ctrls, { Name="Cmd_Set_Program", ControlType="Button", Count=1, UserPin=true, PinStyle="Input",  ButtonType="Trigger", Description="Set Program (EVT PGM,d)" })
  table.insert(ctrls, { Name="Cmd_Set_And_Run", ControlType="Button", Count=1, UserPin=true, PinStyle="Input",  ButtonType="Trigger", Description="Set & Run (EVT SPR,d)" })

  -- Macros (Trigger type - fire and forget, count set by property)
  if numMacros > 0 then
    table.insert(ctrls, { Name="Macros", ControlType="Button", Count=numMacros, UserPin=true, PinStyle="Input", ButtonType="Trigger", Description="Trigger macro 1-N (EVT MAC,n)" })
  end

  -- RDI Remote Device Interface (Trigger type, up to 5 devices x 16 commands)
  if numRDI > 0 then
    table.insert(ctrls, { Name="RDI", ControlType="Button", Count=numRDI*16, UserPin=true, PinStyle="Input", ButtonType="Trigger", Description="RDI device commands (EVT RDI,dev,cmd)" })
  end

  -- OUT: Lights (mutually exclusive Toggle arrays - scrape drives state)
  table.insert(ctrls, { Name="House_Lights", ControlType="Button", Count=5, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="House Lights: 1=None 2=Down 3=Mid1 4=Mid2 5=Up" })
  table.insert(ctrls, { Name="Stage_Lights", ControlType="Button", Count=3, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Stage Lights: 1=None 2=Down 3=Up" })

  -- OUT: Curtain / Masking / Lens (mutually exclusive Toggle)
  table.insert(ctrls, { Name="Curtain", ControlType="Button", Count=3, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Curtain: 1=None 2=Close 3=Open" })
  table.insert(ctrls, { Name="Masking", ControlType="Button", Count=4, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Masking: 1=None 2=Flat 3=Scope 4=Special" })
  table.insert(ctrls, { Name="Lens",    ControlType="Button", Count=4, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Lens: 1=None 2=Flat 3=Scope 4=Special" })

  -- OUT: Sound (mutually exclusive Toggle) + Mute (independent Toggle)
  table.insert(ctrls, { Name="Sound", ControlType="Button", Count=9, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Sound: 1=None 2=Aux1 3=Aux2 4=Dig1 5=Dig2 6=Mono 7=NonSync 8=SR 9=SVA" })
  table.insert(ctrls, { Name="Mute",  ControlType="Button", Count=1, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Sound Mute" })

  -- OUT: Digital Projectors (Toggle - state driven by RST polling)
  table.insert(ctrls, { Name="Dig1_Power",    ControlType="Button", Count=1, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Dig Proj1 Power" })
  table.insert(ctrls, { Name="Dig1_Video",    ControlType="Button", Count=1, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Dig Proj1 Video" })
  table.insert(ctrls, { Name="Dig2_Power",    ControlType="Button", Count=1, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Dig Proj2 Power" })
  table.insert(ctrls, { Name="Dig2_Video",    ControlType="Button", Count=1, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Dig Proj2 Video" })
  table.insert(ctrls, { Name="Aux_Projector", ControlType="Button", Count=1, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Slide Projector" })

  -- Aux digital outputs 1-16 (Toggle - state driven by scrape)
  table.insert(ctrls, { Name="Aux_Out", ControlType="Button", Count=16, UserPin=true, PinStyle="Both", ButtonType="Toggle", Description="Aux Outputs 1-16" })

  -- Web scrape output/input flag indicators (LED indicators, driven by scrape)
  table.insert(ctrls, { Name="Outputs", ControlType="Indicator", IndicatorType="Led", Count=44, UserPin=true, PinStyle="Output", Description="Output flags (web scrape)" })
  table.insert(ctrls, { Name="Inputs",  ControlType="Indicator", IndicatorType="Led", Count=31, UserPin=true, PinStyle="Output", Description="Input flags (web scrape)" })

  -- Debug text outputs (selectable pin visibility via Show_Debug property)
  table.insert(ctrls, { Name="Last_Tx",    ControlType="Text", Count=1, UserPin=true, PinStyle="Output", Description="Last command sent to eCNA" })
  table.insert(ctrls, { Name="Last_Rx",    ControlType="Text", Count=1, UserPin=true, PinStyle="Output", Description="Last response received from eCNA" })
  table.insert(ctrls, { Name="Last_Error", ControlType="Text", Count=1, UserPin=true, PinStyle="Output", Description="Last error message" })

  return ctrls
end

-- ============================================================
-- PROPERTIES: User-configurable options shown in Q-SYS Designer
-- ============================================================
function GetProperties()
  return {
    { Name="Num_Macros",  Type="integer",  Min=0,   Max=50, Value=50 },
    { Name="Num_RDI",     Type="integer",  Min=0,   Max=5,  Value=5  },
    { Name="Poll_Rate",   Type="integer",  Min=1,   Max=60, Value=30 },
    { Name="Scrape_Rate", Type="integer",  Min=1,   Max=60, Value=3  },
    { Name="Show Debug Tab",  Type="boolean",  Value=false },
  }
end

function RectifyProperties(props)
  return props
end

-- ============================================================
-- PAGES: Tabs shown in the plugin UI
-- Macros and RDI tabs hidden if count is 0
-- Debug tab hidden unless Show_Debug property is true
-- ============================================================
function GetPages(props)
  local pages = {}
  for _, name in ipairs(buildPageList(props)) do
    table.insert(pages, { name = name })
  end
  return pages
end

-- ============================================================
-- LAYOUT: Per-page UI layout
-- Q-SYS calls this function once per page switch (driven by
-- the auto-injected page_index property). Only the current
-- page's controls and graphics are emitted.
-- ============================================================
function GetControlLayout(props)
  local layout   = {}
  local graphics = {}
  local pages    = buildPageList(props)
  local CurrentPage = pages[props["page_index"].Value]
  local numMacros = props["Num_Macros"] and props["Num_Macros"].Value or 50
  local numRDI    = props["Num_RDI"]    and props["Num_RDI"].Value    or 5

  local LX  = 10    -- left margin
  local W   = 540   -- page width
  local FX  = 130   -- field/control start x

  -- Section header (horizontal rule with centred text)
  local function hdr(y, text, size)
    table.insert(graphics, { Type="Header", Text=text, Position={LX, y}, Size={W-20, size or 16} })
  end
  -- Right-aligned label (used for row labels left of controls)
  local function lbl(x, y, w, text, size)
    table.insert(graphics, { Type="Label", Text=text, Position={x, y}, Size={w, size or 18},
      HTextAlign="Right", FontSize=size and math.floor(size*0.75) or 12 })
  end
  -- Left-aligned small label (used for button labels, column headers)
  local function textlbl(x, y, w, text, size, align)
    table.insert(graphics, { Type="Label", Text=text, Position={x, y}, Size={w, size or 14},
      HTextAlign=align or "Left", FontSize=size and math.floor(size*0.75) or 11 })
  end

  -- ================================================================
  -- SETUP TAB: Connection, device info, credits
  -- ================================================================
  if CurrentPage == "Setup" then
    local y = 8
    -- Eprad logo, centred
    table.insert(graphics, {
      Type     = "Image",
      Image    = "",
      Position = {(W-300)/2, y},
      Size     = {300, 64}
    })
    y = y + 74

    hdr(y, 'Connection', 18)
    y = y + 24
    lbl(LX, y, 115, 'IP Address:', 16)
    layout["IP_ADDRESS"] = { PrettyName="Setup~IP Address", Style="Text", Position={FX,y}, Size={220,22} }
    y = y + 28
    lbl(LX, y, 115, 'TCP Port:', 16)
    layout["TCP_PORT"] = { PrettyName="Setup~TCP Port", Style="Text", Position={FX,y}, Size={80,22} }
    y = y + 28
    lbl(LX, y, 115, 'Status:', 16)
    layout["Status_LED"]        = { PrettyName="Setup~Status LED",  Style="Led",  IsReadOnly=true, Position={FX, y+5},    Size={14,14} }
    layout["Status"] = { PrettyName="Setup~Status",      Style="Text", IsReadOnly=true, Position={FX+20, y},   Size={238,22} }
    layout["Reconnect"]         = { PrettyName="Setup~Reconnect",   Style="Button", ButtonStyle="Momentary", Legend="Reconnect", Position={FX+264,y}, Size={88,22} }
    y = y + 36

    hdr(y, 'Device Info', 18)
    y = y + 24
    lbl(LX, y, 115, 'Model:', 16)
    layout["Model"]            = { PrettyName="Setup~Model",    Style="Text", IsReadOnly=true, Position={FX,y}, Size={180,22} }
    y = y + 28
    lbl(LX, y, 115, 'Firmware:', 16)
    layout["Firmware_Version"] = { PrettyName="Setup~Firmware", Style="Text", IsReadOnly=true, Position={FX,y}, Size={180,22} }
    y = y + 36

    hdr(y, 'Credits', 18)
    y = y + 24
    table.insert(graphics, { Type="Label", Text="\xc2\xa9 2026 By Jay Wyatt and Steve Guttag.  Built with Claude AI.",
      Position={LX, y}, Size={W-20, 18}, HTextAlign="Left", FontSize=12 })
    y = y + 26
    table.insert(graphics, { Type="Label",
      Text="This plugin may be freely distributed. It is supplied as-is and without support. Use at your own risk.",
      Position={LX, y}, Size={W-20, 16}, HTextAlign="Left", FontSize=10 })
    y = y + 18
    table.insert(graphics, { Type="Label",
      Text="There are no expressed or implied warranties. This plugin is not a product of Eprad.",
      Position={LX, y}, Size={W-20, 16}, HTextAlign="Left", FontSize=10 })
    y = y + 24
    -- STG logo, centred below Credits
    table.insert(graphics, {
      Type     = "Image",
      Image    = "",
      Position = {(W-21)/2, y},
      Size     = {21, 50}
    })
    -- Version number, lower-right corner
    table.insert(graphics, { Type="Label", Text="Version "..PluginInfo.Version,
      Position={W-100, y+44}, Size={90, 14}, HTextAlign="Right", FontSize=9 })

  -- ================================================================
  -- OUTPUTS TAB: All eCNA outputs grouped by type
  -- Toggle buttons send OUT commands and reflect state from scrape
  -- ================================================================
  elseif CurrentPage == "Outputs" then
    local BW, BH, BS = 54, 26, 56   -- button width, height, stride
    local y = 10

    -- Digital Projectors (state from RST polling)
    lbl(LX, y, 115, 'Dig Proj1 Pwr:', 14)
    layout["Dig1_Power"] = { PrettyName="Outputs~Dig Proj1 Power", Style="Button", ButtonStyle="Toggle", Legend="Dig Proj1 Power", Position={FX, y}, Size={130, BH} }
    y = y + BH+4
    lbl(LX, y, 115, 'Dig Proj1 Vid:', 14)
    layout["Dig1_Video"] = { PrettyName="Outputs~Dig Proj1 Video", Style="Button", ButtonStyle="Toggle", Legend="Dig Proj1 Video", Position={FX, y}, Size={130, BH} }
    y = y + BH+4
    lbl(LX, y, 115, 'Dig Proj2 Pwr:', 14)
    layout["Dig2_Power"] = { PrettyName="Outputs~Dig Proj2 Power", Style="Button", ButtonStyle="Toggle", Legend="Dig Proj2 Power", Position={FX, y}, Size={130, BH} }
    y = y + BH+4
    lbl(LX, y, 115, 'Dig Proj2 Vid:', 14)
    layout["Dig2_Video"] = { PrettyName="Outputs~Dig Proj2 Video", Style="Button", ButtonStyle="Toggle", Legend="Dig Proj2 Video", Position={FX, y}, Size={130, BH} }
    y = y + BH+4
    lbl(LX, y, 115, 'Slide Projector:', 14)
    layout["Aux_Projector"] = { PrettyName="Outputs~Slide Projector", Style="Button", ButtonStyle="Toggle", Legend="Slide Projector", Position={FX, y}, Size={130, BH} }
    y = y + BH+8

    -- House Lights (mutually exclusive, state from scrape)
    local HLLabels = {"None","Down","Mid1","Mid2","Up"}
    lbl(LX, y, 115, 'House Lights:', 14)
    for i,txt in ipairs(HLLabels) do
      layout["House_Lights "..i] = { PrettyName="Outputs~House Lights/"..txt, Style="Button", ButtonStyle="Toggle", Legend=txt, Position={FX+(i-1)*BS, y}, Size={BW, BH} }
    end
    y = y + BH+4

    -- Stage Lights
    local SLLabels = {"None","Down","Up"}
    lbl(LX, y, 115, 'Stage Lights:', 14)
    for i,txt in ipairs(SLLabels) do
      layout["Stage_Lights "..i] = { PrettyName="Outputs~Stage Lights/"..txt, Style="Button", ButtonStyle="Toggle", Legend=txt, Position={FX+(i-1)*BS, y}, Size={BW, BH} }
    end
    y = y + BH+4

    -- Curtain
    local CurtLabels = {"None","Close","Open"}
    lbl(LX, y, 115, 'Curtain:', 14)
    for i,txt in ipairs(CurtLabels) do
      layout["Curtain "..i] = { PrettyName="Outputs~Curtain/"..txt, Style="Button", ButtonStyle="Toggle", Legend=txt, Position={FX+(i-1)*BS, y}, Size={BW, BH} }
    end
    y = y + BH+4

    -- Masking
    local MskLabels = {"None","Flat","Scope","Special"}
    lbl(LX, y, 115, 'Masking:', 14)
    for i,txt in ipairs(MskLabels) do
      layout["Masking "..i] = { PrettyName="Outputs~Masking/"..txt, Style="Button", ButtonStyle="Toggle", Legend=txt, Position={FX+(i-1)*BS, y}, Size={BW, BH} }
    end
    y = y + BH+4

    -- Lens
    local LensLabels = {"None","Flat","Scope","Special"}
    lbl(LX, y, 115, 'Lens:', 14)
    for i,txt in ipairs(LensLabels) do
      layout["Lens "..i] = { PrettyName="Outputs~Lens/"..txt, Style="Button", ButtonStyle="Toggle", Legend=txt, Position={FX+(i-1)*BS, y}, Size={BW, BH} }
    end
    y = y + BH+4

    -- Sound: row1 = None Aux1 Aux2 Dig1 Dig2, row2 = Mono NonSync SR SVA + Mute
    local SndLabels = {"None","Aux1","Aux2","Dig1","Dig2","Mono","NonSync","SR","SVA"}
    lbl(LX, y, 115, 'Sound:', 14)
    for i=1,5 do
      layout["Sound "..i] = { PrettyName="Outputs~Sound/"..SndLabels[i], Style="Button", ButtonStyle="Toggle", Legend=SndLabels[i], Position={FX+(i-1)*BS, y}, Size={BW, BH} }
    end
    for i=6,9 do
      layout["Sound "..i] = { PrettyName="Outputs~Sound/"..SndLabels[i], Style="Button", ButtonStyle="Toggle", Legend=SndLabels[i], Position={FX+(i-6)*BS, y+BH+4}, Size={BW, BH} }
    end
    layout["Mute"] = { PrettyName="Outputs~Mute", Style="Button", ButtonStyle="Toggle", Legend="Mute", Position={FX+4*BS, y+BH+4}, Size={BW, BH} }
    y = y + (BH+4)*2 + 8

    -- Aux Outputs 1-16: text label above each button, 8 per row
    hdr(y, 'Aux Outputs 1-16', 16)
    y = y + 22
    local auxBW = 54
    local auxStride = auxBW + 4
    for i=1,16 do
      local col = (i-1) % 8
      local row = math.floor((i-1)/8)
      local bx  = LX + col*auxStride
      local by  = y + row*46
      -- Text label above button
      textlbl(bx, by, auxBW, "Out "..i, 14, "Center")
      layout["Aux_Out "..i] = { PrettyName="Outputs~Aux Out "..i, Style="Button", ButtonStyle="Toggle", Position={bx, by+18}, Size={auxBW, BH} }
    end

  -- ================================================================
  -- INPUTS TAB: Web scrape input flags as LEDs with labels
  -- Two columns: In1-In16 on left, system inputs on right
  -- ================================================================
  elseif CurrentPage == "Inputs" then
    local y = 10
    local LED = 16   -- LED size
    local LS  = 22   -- row stride

    hdr(y, 'Input Flags', 20)
    y = y + 42

    local col1 = {}   -- {index, name} for In1-In16
    local col2 = {}   -- {index, name} for system inputs
    local InFlagNames = {
      "Stop","Start","Dig1 Cue","Dig1 Fault","Dig1 Stop","Dig1 Start",
      "Dig2 Cue","Dig2 Fault","Dig2 Stop","Dig2 Start",
      "Bypass","Program Abort","Pause","In1","In2","In3","In4",
      "Fire Stop","In5","In6","In7","In8","In9","In10","In11","In12",
      "In13","In14","In15","In16","Cancel"
    }
    for i, name in ipairs(InFlagNames) do
      if name:sub(1,2) == "In" and tonumber(name:sub(3)) then
        table.insert(col1, {i, name})
      else
        table.insert(col2, {i, name})
      end
    end

    local colW = math.floor((W-20) / 2)

    -- Column headers sit 18px above the first row
    textlbl(LX,       y-20, colW, "General Inputs", 16)
    textlbl(LX+colW,  y-20, colW, "System Inputs",  16)

    -- Column 1: In1-In16
    local y1 = y
    for _, entry in ipairs(col1) do
      layout["Inputs "..entry[1]] = { PrettyName="Inputs~"..entry[2], Style="Led", IsReadOnly=true, Color="green", Position={LX, y1+3}, Size={LED, LED} }
      textlbl(LX+LED+6, y1+2, colW-LED-10, entry[2], 16)
      y1 = y1 + LS
    end

    -- Column 2: System inputs
    local x2 = LX + colW
    local y2 = y
    for _, entry in ipairs(col2) do
      layout["Inputs "..entry[1]] = { PrettyName="Inputs~"..entry[2], Style="Led", IsReadOnly=true, Color="green", Position={x2, y2+3}, Size={LED, LED} }
      textlbl(x2+LED+6, y2+2, colW-LED-10, entry[2], 16)
      y2 = y2 + LS
    end

  -- ================================================================
  -- MACROS TAB: Trigger buttons with text labels above (no legends)
  -- ================================================================
  elseif CurrentPage == "Macros" then
    local y = 10
    hdr(y, 'Macros', 18)
    y = y + 24
    local cols  = 10
    local bw    = math.floor((W-20) / cols) - 2
    local bh    = 24
    for i = 1, numMacros do
      local col = (i-1) % cols
      local row = math.floor((i-1) / cols)
      local bx  = LX + col*(bw+2)
      local by  = y + row*42
      -- Text label centred above button, no legend on button itself
      textlbl(bx, by, bw+2, "Macro "..i, 14, "Center")
      layout["Macros "..i] = { PrettyName="Macros~Macro "..i, Style="Button", ButtonStyle="Trigger", Position={bx, by+16}, Size={bw, bh} }
    end

  -- ================================================================
  -- RDI TAB: 5 devices x 16 commands, text labels above Trigger buttons
  -- ================================================================
  elseif CurrentPage == "RDI" then
    local y = 10
    local bw     = 54
    local bh     = 24
    local stride = 56
    for dev = 1, numRDI do
      hdr(y, 'RDI '..dev, 18)
      y = y + 22
      for cmd = 1, 16 do
        local col = (cmd-1) % 8
        local row = math.floor((cmd-1) / 8)
        local idx = (dev-1)*16 + cmd
        local bx  = LX + col*stride
        local by  = y + row*42
        -- Text label: 'RDI N-N' centred above button
        textlbl(bx, by, bw, "RDI "..dev.."-"..cmd, 14, "Center")
        layout["RDI "..idx] = { PrettyName="RDI~RDI "..dev.." Cmd "..cmd, Style="Button", ButtonStyle="Trigger", Position={bx, by+16}, Size={bw, bh} }
      end
      y = y + 2*42 + 8
    end

  -- ================================================================
  -- PROGRAM TAB: Transport controls, program selection, run state
  -- ================================================================
  elseif CurrentPage == "Program" then
    local y = 10
    local BH2 = 30   -- taller buttons for program controls

    hdr(y, 'Transport', 18)
    y = y + 26
    layout["Cmd_Start"]        = { PrettyName="Program~Start",        Style="Button", ButtonStyle="Trigger",   Legend="Start",        Position={LX,    y}, Size={84,BH2} }
    layout["Cmd_Stop"]         = { PrettyName="Program~Stop",         Style="Button", ButtonStyle="Trigger",   Legend="Stop",         Position={LX+88, y}, Size={84,BH2} }
    layout["Cmd_Cue"]          = { PrettyName="Program~Cue",          Style="Button", ButtonStyle="Trigger",   Legend="Cue",          Position={LX+176,y}, Size={84,BH2} }
    layout["Cmd_Abort"]        = { PrettyName="Program~Abort",        Style="Button", ButtonStyle="Trigger",   Legend="Abort",        Position={LX+264,y}, Size={84,BH2} }
    y = y + BH2+6
    layout["Cmd_Fault"]        = { PrettyName="Program~Set Fault",    Style="Button", ButtonStyle="Trigger",   Legend="Set Fault",    Position={LX,    y}, Size={94,BH2} }
    layout["Cmd_Clear_Fault"]  = { PrettyName="Program~Clear Fault",  Style="Button", ButtonStyle="Trigger",   Legend="Clear Fault",  Position={LX+98, y}, Size={94,BH2} }
    layout["Cmd_Reset"]        = { PrettyName="Program~Reset Fault",  Style="Button", ButtonStyle="Trigger",   Legend="Reset Fault",  Position={LX+196,y}, Size={94,BH2} }
    layout["Cmd_Cancel_Alarm"] = { PrettyName="Program~Cancel Alarm", Style="Button", ButtonStyle="Trigger",   Legend="Cancel Alarm", Position={LX+294,y}, Size={108,BH2} }
    y = y + BH2+10

    hdr(y, 'Program Selection', 18)
    y = y + 26
    lbl(LX, y, 120, 'Program #:', 16)
    layout["Set_Program"]      = { PrettyName="Program~Set Program",  Style="ComboBox", Position={FX+5,y}, Size={120,22} }
    layout["Cmd_Set_Program"]  = { PrettyName="Program~Set Prog",     Style="Button", ButtonStyle="Trigger", Legend="Set Prog",  Position={FX+130,y}, Size={80,22} }
    layout["Cmd_Set_And_Run"]  = { PrettyName="Program~Set and Run",  Style="Button", ButtonStyle="Trigger", Legend="Set & Run", Position={FX+214,y}, Size={88,22} }
    y = y + 36

    hdr(y, 'Run State', 18)
    y = y + 26
    local stateRows = {
      {"Control_State",  "Control State"},
      {"Stopped_State",  "Stopped State"},
      {"Cue_Number",     "Cue Number"},
      {"Program_Number", "Program Number"},
      {"Segment_Name",   "Segment Name"},
      {"Segment_Index",  "Segment Index"},
      {"CAI_CMD_Access", "CMD Access"},
    }
    for _, row in ipairs(stateRows) do
      lbl(LX, y, 120, row[2]..':', 16)
      layout[row[1]] = { PrettyName="Program~"..row[2], Style="Text", IsReadOnly=true, Position={FX+5,y}, Size={190,22} }
      y = y + 28
    end

  -- ================================================================
  -- DEBUG TAB: Raw TX/RX/Error display (visible via Show_Debug property)
  -- ================================================================
  elseif CurrentPage == "Debug" then
    local y = 10
    hdr(y, 'Debug / Raw', 18)
    y = y + 26
    lbl(LX, y, 115, 'Last TX:', 16)
    layout["Last_Tx"]    = { PrettyName="Debug~Last TX",    Style="Text", IsReadOnly=true, Position={FX,y}, Size={400,22} }
    y = y + 28
    lbl(LX, y, 115, 'Last RX:', 16)
    layout["Last_Rx"]    = { PrettyName="Debug~Last RX",    Style="Text", IsReadOnly=true, Position={FX,y}, Size={400,22} }
    y = y + 28
    lbl(LX, y, 115, 'Last Error:', 16)
    layout["Last_Error"] = { PrettyName="Debug~Last Error", Style="Text", IsReadOnly=true, Position={FX,y}, Size={400,22} }
  end

  return layout, graphics
end

-- ============================================================
-- RUNTIME: Executes on Q-SYS Core when Controls table is available
-- All live device communication happens in this block
-- ============================================================
if Controls then

  -- ── Configuration ──────────────────────────────────────────
  local TCP_PORT    = 13002  -- default port; overridden by Setup page TCP Port field
  -- Use property values; fall back to defaults if not set
  local POLL_RATE   = (Properties["Poll_Rate"]   and Properties["Poll_Rate"].Value   or 30)
  local SCRAPE_RATE = (Properties["Scrape_Rate"] and Properties["Scrape_Rate"].Value or 3)
  local SHOW_DEBUG  = Properties["Show Debug Tab"] and Properties["Show Debug Tab"].Value or false

  -- ── Flag name tables (used to initialise LED legends) ──────
  local OutFlagNames = {
    "Dig Proj1 Power","Dig Proj1 Video","Dig Proj2 Power","Dig Proj2 Video",
    "House Lights Down","House Lights Mid1","House Lights Mid2","House Lights Up",
    "Stage Lights Down","Stage Lights Up","Curtain Close","Curtain Open",
    "Mask Flat","Mask Scope","Mask Special","Lens Flat","Lens Scope","Lens Special",
    "Slide Projector","Sound Aux 1","Sound Aux 2","Sound Digital 1","Sound Digital 2",
    "Sound Mono","Sound Mute","Sound Non-Sync","Sound SR","Sound SVA",
    "Out1","Out2","Out3","Out4","Out5","Out6","Out7","Out8",
    "Out9","Out10","Out11","Out12","Out13","Out14","Out15","Out16"
  }
  local InFlagNames = {
    "Stop","Start","Dig1 Cue","Dig1 Fault","Dig1 Stop","Dig1 Start",
    "Dig2 Cue","Dig2 Fault","Dig2 Stop","Dig2 Start",
    "Bypass","Program Abort","Pause","In1","In2","In3","In4",
    "Fire Stop","In5","In6","In7","In8","In9","In10","In11","In12",
    "In13","In14","In15","In16","Cancel"
  }

  -- ── State variables ────────────────────────────────────────
  local psn          = 0       -- Packet Sequence Number (0-65535, wraps)
  local sock         = TcpSocket.New()  -- CAI TCP connection (port 13002)
  local pollTimer    = Timer.New()      -- Fires RST poll at POLL_RATE seconds
  local reconnectTmr = Timer.New()      -- Fires reconnect attempt after disconnect
  local rxBuf        = ""      -- Receive buffer for incoming CAI data
  local isConnected  = false   -- True when CAI TCP socket is connected
  local httpSock     = nil     -- forward declaration; assigned after httpSock section

  -- IP address validator: rejects empty, 0.0.0.0, or malformed addresses
  local function isValidIP(ip)
    if not ip or #ip == 0 then return false end
    local a,b,c,d = ip:match("^(%d+)%.(%d+)%.(%d+)%.(%d+)$")
    if not a then return false end
    a,b,c,d = tonumber(a),tonumber(b),tonumber(c),tonumber(d)
    if a==0 and b==0 and c==0 and d==0 then return false end
    return (a<=255 and b<=255 and c<=255 and d<=255)
  end

  -- ── Debug helper: logs to Q-SYS debug window if Show_Debug is true ──
  -- Debug output: always prints to Q-SYS debug window when ShowDebug=true in PluginInfo
  local function dbg(msg)
    print('[eCNA] ' .. tostring(msg))
  end

  -- ── CAI Protocol helpers ────────────────────────────────────
  -- Compute CAI checksum: sum of all ASCII bytes in the prefix, mod 65536
  local function checksum(s)
    local sum = 0
    for i = 1, #s do sum = sum + string.byte(s, i) end
    return tostring(sum % 65536)
  end

  -- Increment and return the next Packet Sequence Number (wraps at 65535)
  local function nextPSN()
    psn = (psn + 1) % 65536
    return tostring(psn)
  end

  -- Build and send a CAI command: CMD,<body>,<checksum>\r\n
  local function sendCmd(body)
    local prefix = "CMD,"..body..","
    local msg    = prefix..checksum(prefix).."\r\n"
    Controls.Last_Tx.String = msg:gsub("\r\n","")
    dbg("TX: " .. msg:gsub("\r\n",""))
    if isConnected then
      sock:Write(msg)
    else
      Controls.Last_Error.String = "Not connected - dropped: "..msg:gsub("\r\n","")
    end
  end

  -- Split a comma-separated string into a table
  local function split(str, sep)
    local t = {}
    for field in str:gmatch("([^"..sep.."]*)"..sep.."?") do
      if field ~= "" then table.insert(t, field) end
    end
    return t
  end

  -- Set one button in a group active (lit), clear all others
  local function setExclusive(group, idx)
    for i, c in ipairs(group) do c.Boolean = (i == idx) end
  end

  -- ── Q-SYS Status indicator values ──────────────────────────
  -- Used for Status (text box) and Status_LED
  -- 0=OK(green) 1=Compromised(yellow) 2=Fault(red)
  -- 3=NotPresent(grey) 4=Missing(orange) 5=Initializing(blue)
  local STATUS_OK=0; local STATUS_FAULT=2
  local STATUS_MISSING=4; local STATUS_INITIALIZING=5

  -- Update both the status text box and the LED indicator
  local function setStatus(value, msg)
    Controls.Status.String = msg
    Controls.Status.Value  = value
    Controls.Status_LED.Value         = value
    dbg("Status: " .. msg)
  end

  -- ── RST Response Parser ─────────────────────────────────────
  -- Parses the RSP,RST response which contains full device state
  local function parseStatusRecord(fields)
    if #fields < 6 or fields[4] ~= "0" then
      if fields[4] and fields[4] ~= "0" then
        Controls.Last_Error.String = "RST error "..fields[4]
        dbg("RST error: " .. fields[4])
      end
      return
    end
    local f = fields
    Controls.Control_State.String    = f[6]  or ""
    Controls.Stopped_State.String    = f[7]  or ""
    Controls.Cue_Number.String       = f[8]  or ""
    -- Note: Dig projector and Aux_Projector button states are driven solely
    -- by the web scrape (flags 1-4, 19) to avoid blinking from dual updates.
    -- Program/segment info
    Controls.Segment_Index.String    = f[29] or ""
    Controls.Segment_Name.String     = f[30] or ""
    Controls.CAI_CMD_Access.String   = f[31] or ""
    Controls.Program_Number.String   = f[32] or ""
    dbg("RST: state=" .. (f[6] or "") .. " seg=" .. (f[30] or ""))
  end

  -- ── RID Response Parser ─────────────────────────────────────
  -- Parses the RSP,RID response containing model and firmware version
  local function parseRID(fields)
    if #fields < 7 or fields[4] ~= "0" then return end
    Controls.Model.String = fields[5] or ""
    local ver = tonumber(fields[6])
    Controls.Firmware_Version.String = ver and string.format("%.3f", ver/1000) or (fields[6] or "")
    dbg("RID: model=" .. (fields[5] or "") .. " fw=" .. (fields[6] or ""))
  end

  -- ── Unsolicited Event Parser ────────────────────────────────
  -- Handles RPT,EVT messages sent by the eCNA without being polled
  -- Re-polls RST on state-changing events for immediate UI update
  local function parseRPTEVT(fields)
    local evt = fields[4] or ""
    Controls.Last_Rx.String = "EVT: "..evt
    dbg("RPT EVT: " .. evt)
    if evt=="START" or evt=="IDLE"    or evt=="ALLSTOP"
    or evt=="DP1ON" or evt=="DP1OFF"  or evt=="DV1ON"  or evt=="DV1OFF"
    or evt=="DP2ON" or evt=="DP2OFF"  or evt=="DV2ON"  or evt=="DV2OFF"
    or evt=="CUE"   or evt=="FIRESTOP" then
      Timer.CallAfter(function() sendCmd("RST,"..nextPSN()) end, 0.2)
    end
  end

  -- ── Incoming Line Processor ─────────────────────────────────
  -- Routes each complete CAI response line to the appropriate parser
  local function processLine(line)
    line = line:gsub("[\r\n]","")
    if #line == 0 then return end
    Controls.Last_Rx.String = line
    dbg("RX: " .. line)
    local f = split(line, ",")
    if #f < 2 then return end
    if f[1] == "RSP" then
      if     f[2] == "RST" or f[2] == "XST" then parseStatusRecord(f)
      elseif f[2] == "RID"                   then parseRID(f)
      elseif f[2] == "ERR"                   then
        Controls.Last_Error.String = line
        dbg("ERR: " .. line)
      end
    elseif f[1] == "RPT" and f[2] == "EVT" then
      parseRPTEVT(f)
    end
  end

  -- ── CAI TCP Socket Handler ──────────────────────────────────
  -- Manages connection state and incoming data buffering
  sock.EventHandler = function(sock, evt, err)
    if evt == TcpSocket.Events.Connected then
      isConnected = true
      setStatus(STATUS_OK, "OK")
      Controls.Last_Error.String = ""
      -- Request device ID and enable unsolicited event reports
      sendCmd("RID,"..nextPSN())
      sendCmd("CFG,"..nextPSN()..",RPTON,N")
      -- Short delay before first RST poll to let device settle
      Timer.CallAfter(function() sendCmd("RST,"..nextPSN()) end, 0.5)
      pollTimer:Start(POLL_RATE)
    elseif evt == TcpSocket.Events.Data then
      -- Accumulate data and process complete lines
      rxBuf = rxBuf .. sock:Read(sock.BufferLength)
      while true do
        local nl = rxBuf:find("\n")
        if not nl then break end
        local line = rxBuf:sub(1, nl)
        rxBuf = rxBuf:sub(nl+1)
        local ok, err = pcall(processLine, line)
        if not ok then
          Controls.Last_Error.String = "Parse error: "..(err or "")
          dbg("Parse error: " .. tostring(err))
        end
      end
    elseif evt == TcpSocket.Events.Closed
        or evt == TcpSocket.Events.Reconnect
        or evt == TcpSocket.Events.Error then
      isConnected = false
      setStatus(STATUS_FAULT, (err and err ~= "") and ("Disconnected: "..err) or "Disconnected")
      pollTimer:Stop()
      reconnectTmr:Start(5)  -- retry connection after 5 seconds
    end
  end

  -- ── Timers ──────────────────────────────────────────────────
  -- RST poll: sends status request at POLL_RATE interval
  pollTimer.EventHandler = function()
    if isConnected then
      local ok, err = pcall(function() sendCmd("RST,"..nextPSN()) end)
      if not ok then Controls.Last_Error.String = "Poll error: "..(err or "") end
    end
  end

  -- Reconnect: fires 5 seconds after disconnect, attempts new connection
  reconnectTmr.EventHandler = function()
    reconnectTmr:Stop()
    local ip   = Controls.IP_ADDRESS.String
    local port = tonumber(Controls.TCP_PORT.String)
    if not port or port < 1 then port = TCP_PORT end
    if ip and #ip > 0 then
      setStatus(STATUS_INITIALIZING, "Initializing")
      sock:Connect(ip, port)
    end
  end

  -- ── Connect function ────────────────────────────────────────
  -- Initiates CAI TCP connection using current IP/port settings
  local function connect()
    if isConnected then sock:Disconnect() end
    rxBuf = ""
    local ip   = Controls.IP_ADDRESS.String
    local port = tonumber(Controls.TCP_PORT.String)
    if not port or port < 1 then port = TCP_PORT end
    if isValidIP(ip) then
      setStatus(STATUS_INITIALIZING, "Initializing")
      sock:Connect(ip, port)
    else
      setStatus(STATUS_MISSING, ip and #ip > 0 and "Invalid IP address" or "Missing")
    end
  end

  -- ── Control Event Handlers ──────────────────────────────────
  -- Connect when IP is entered or changed
  Controls.IP_ADDRESS.EventHandler = function()
    if Controls.TCP_PORT.String == "" then
      Controls.TCP_PORT.String = tostring(TCP_PORT)
    end
    connect()
    httpConnected = false
    httpBuf = ""
    local ip = Controls.IP_ADDRESS.String
    if httpSock and isValidIP(ip) then httpSock:Connect(ip, 80) end
  end

  Controls.Reconnect.EventHandler = function() connect() end

  -- Transport command buttons (Trigger type)
  Controls.Cmd_Start.EventHandler        = function() sendCmd("EVT,"..nextPSN()..",STA,Y") end
  Controls.Cmd_Stop.EventHandler         = function() sendCmd("EVT,"..nextPSN()..",STP,Y") end
  Controls.Cmd_Cue.EventHandler          = function() sendCmd("EVT,"..nextPSN()..",CUE,Y") end
  Controls.Cmd_Abort.EventHandler        = function() sendCmd("EVT,"..nextPSN()..",ABT,Y") end
  Controls.Cmd_Fault.EventHandler        = function() sendCmd("EVT,"..nextPSN()..",FLT,Y") end
  Controls.Cmd_Clear_Fault.EventHandler  = function() sendCmd("EVT,"..nextPSN()..",CLR,Y") end
  Controls.Cmd_Reset.EventHandler        = function() sendCmd("EVT,"..nextPSN()..",RES,Y") end
  Controls.Cmd_Cancel_Alarm.EventHandler = function() sendCmd("EVT,"..nextPSN()..",CNL,Y") end

  -- Program selection (Trigger type)
  Controls.Cmd_Set_Program.EventHandler = function()
    sendCmd("EVT,"..nextPSN()..",PGM,"..Controls.Set_Program.String..",Y")
  end
  Controls.Cmd_Set_And_Run.EventHandler = function()
    sendCmd("EVT,"..nextPSN()..",SPR,"..Controls.Set_Program.String..",Y")
  end

  -- Macro triggers (Trigger type, indexed 1-N)
  if Controls.Macros then
    for idx, ctl in ipairs(Controls.Macros) do
      ctl.EventHandler = function() sendCmd("EVT,"..nextPSN()..",MAC,"..idx..",Y") end
    end
  end

  -- RDI triggers (Trigger type, device and command derived from flat index)
  if Controls.RDI then
    for idx, ctl in ipairs(Controls.RDI) do
      local dev = math.ceil(idx/16)
      local cmd = ((idx-1) % 16) + 1
      ctl.EventHandler = function() sendCmd("EVT,"..nextPSN()..",RDI,"..dev..","..cmd..",Y") end
    end
  end

  -- House Lights: mutually exclusive Toggle, sends HLNONE/HLDOWN/etc.
  local HouseLightCodes = {"HLNONE","HLDOWN","HLMID1","HLMID2","HLUP"}
  for idx, ctl in ipairs(Controls.House_Lights) do
    ctl.EventHandler = function()
      setExclusive(Controls.House_Lights, idx)
      sendCmd("OUT,"..nextPSN()..","..HouseLightCodes[idx]..",N")
    end
  end

  -- Stage Lights: mutually exclusive Toggle
  local StageLightCodes = {"SLNONE","SLDOWN","SLUP"}
  for idx, ctl in ipairs(Controls.Stage_Lights) do
    ctl.EventHandler = function()
      setExclusive(Controls.Stage_Lights, idx)
      sendCmd("OUT,"..nextPSN()..","..StageLightCodes[idx]..",N")
    end
  end

  -- Curtain: mutually exclusive Toggle
  local CurtainCodes = {"CURTNONE","CURTCLOS","CURTOPEN"}
  for idx, ctl in ipairs(Controls.Curtain) do
    ctl.EventHandler = function()
      setExclusive(Controls.Curtain, idx)
      sendCmd("OUT,"..nextPSN()..","..CurtainCodes[idx]..",N")
    end
  end

  -- Masking: mutually exclusive Toggle
  local MaskCodes = {"MSKNONE","MSKFLAT","MSKSCOPE","MSKSPECL"}
  for idx, ctl in ipairs(Controls.Masking) do
    ctl.EventHandler = function()
      setExclusive(Controls.Masking, idx)
      sendCmd("OUT,"..nextPSN()..","..MaskCodes[idx]..",N")
    end
  end

  -- Lens: mutually exclusive Toggle
  local LensCodes = {"LENNONE","LENSFLAT","LENSCOPE","LENSPECL"}
  for idx, ctl in ipairs(Controls.Lens) do
    ctl.EventHandler = function()
      setExclusive(Controls.Lens, idx)
      sendCmd("OUT,"..nextPSN()..","..LensCodes[idx]..",N")
    end
  end

  -- Sound: mutually exclusive Toggle
  local SoundCodes = {"SNDNONE","SNDAUX1","SNDAUX2","SNDDIG1","SNDDIG2","SNDMONO","SNDNSYNC","SNDSR","SNDSVA"}
  for idx, ctl in ipairs(Controls.Sound) do
    ctl.EventHandler = function()
      setExclusive(Controls.Sound, idx)
      sendCmd("OUT,"..nextPSN()..","..SoundCodes[idx]..",N")
    end
  end

  -- Mute: independent Toggle
  Controls.Mute.EventHandler = function()
    sendCmd("OUT,"..nextPSN()..","..(Controls.Mute.Boolean and "MUTEON" or "MUTEOFF")..",N")
  end

  -- Digital Projector toggles (send ON/OFF commands)
  Controls.Dig1_Power.EventHandler    = function() sendCmd("OUT,"..nextPSN()..","..(Controls.Dig1_Power.Boolean    and "DP1ON"   or "DP1OFF")  ..",Y") end
  Controls.Dig1_Video.EventHandler    = function() sendCmd("OUT,"..nextPSN()..","..(Controls.Dig1_Video.Boolean    and "DV1ON"   or "DV1OFF")  ..",Y") end
  Controls.Dig2_Power.EventHandler    = function() sendCmd("OUT,"..nextPSN()..","..(Controls.Dig2_Power.Boolean    and "DP2ON"   or "DP2OFF")  ..",Y") end
  Controls.Dig2_Video.EventHandler    = function() sendCmd("OUT,"..nextPSN()..","..(Controls.Dig2_Video.Boolean    and "DV2ON"   or "DV2OFF")  ..",Y") end
  Controls.Aux_Projector.EventHandler = function() sendCmd("OUT,"..nextPSN()..","..(Controls.Aux_Projector.Boolean and "SPROJON" or "SPROJOFF")..",Y") end

  -- Aux Outputs 1-16
  for idx, ctl in ipairs(Controls.Aux_Out) do
    ctl.EventHandler = function()
      sendCmd("OUT,"..nextPSN()..","..(Controls.Aux_Out[idx].Boolean and "OUT"..idx.."ON" or "OUT"..idx.."OFF")..",Y")
    end
  end

  -- ── Web Scrape via raw TCP HTTP/1.0 ─────────────────────────
  -- Uses a persistent TCP socket to port 80.
  -- On each scrapeTimer tick, sends a GET request if connected,
  -- or initiates a new connection if not.
  -- On connection close (HTTP/1.0 closes after response), parses
  -- the XML body and reconnects for next poll.
  httpSock            = TcpSocket.New()  -- assigns to forward-declared upvalue
  local httpBuf       = ""
  local httpConnected = false
  local scrapeTimer   = Timer.New()
  local httpReconnTmr = Timer.New()

  -- Send HTTP GET request for the I/O flag XML
  local function httpRequest()
    local ip = Controls.IP_ADDRESS.String
    if not isValidIP(ip) then return end
    if not httpConnected then
      httpSock:Connect(ip, 80)
      return
    end
    local req = "GET /rtIoFDetail.xml HTTP/1.0\r\n"
               .."Host: "..ip.."\r\n"
               .."Authorization: Basic YWRtaW46MzE0MTU5\r\n"
               .."Connection: close\r\n"
               .."\r\n"
    httpSock:Write(req)
    dbg("HTTP GET /rtIoFDetail.xml")
  end

  -- ── Web Scrape XML Parser ────────────────────────────────────
  -- Parses <outs> and <ins> flag lists from the XML response
  -- Updates button states and LED indicators accordingly
  local function csvSplit(s)
    local t, pos = {}, 1
    while true do
      local nx = string.find(s, ",", pos, true)
      if nx == nil then
        if pos <= #s then table.insert(t, string.sub(s, pos)) end
        break
      end
      table.insert(t, string.sub(s, pos, nx-1))
      pos = nx + 1
    end
    return t
  end

  local function scrape(data)
    local function fi(sub) return string.find(data, sub, 1, true) or 0 end
    local os, oe  = fi("<outs>"),  fi("</outs>")
    local is_, ie = fi("<ins>"),   fi("</ins>")
    if os == 0 or is_ == 0 then return end

    -- Parse comma-separated flag numbers from XML tags
    local OutputFlags, InputFlags = {}, {}
    for _, v in ipairs(csvSplit(string.sub(data, os+6, oe-1)))  do table.insert(OutputFlags, tonumber(v)) end
    for _, v in ipairs(csvSplit(string.sub(data, is_+5, ie-1))) do table.insert(InputFlags,  tonumber(v)) end
    dbg("Scrape: " .. #OutputFlags .. " out flags, " .. #InputFlags .. " in flags")

    -- Helper: returns true if flag n is in the active output list
    local function flagActive(n)
      for _, v in ipairs(OutputFlags) do if v == n then return true end end
      return false
    end

    -- Update Outputs and Inputs LED indicators
    for idx = 1, #Controls.Outputs do
      Controls.Outputs[idx].Value = flagActive(idx) and 1 or 0
    end
    for idx = 1, #Controls.Inputs do
      local a = false
      -- Input flags are offset by 3 from their InFlagNames index (per eCNA manual)
      for _, v in ipairs(InputFlags) do if (v - 3) == idx then a = true; break end end
      Controls.Inputs[idx].Value = a and 1 or 0
    end

    -- Sync mutually exclusive output button groups from active flags
    -- House Lights: flags 5=Down, 6=Mid1, 7=Mid2, 8=Up, none=None
    if     flagActive(8)  then setExclusive(Controls.House_Lights, 5)
    elseif flagActive(7)  then setExclusive(Controls.House_Lights, 4)
    elseif flagActive(6)  then setExclusive(Controls.House_Lights, 3)
    elseif flagActive(5)  then setExclusive(Controls.House_Lights, 2)
    else                       setExclusive(Controls.House_Lights, 1) end

    -- Stage Lights: flags 9=Down, 10=Up
    if     flagActive(10) then setExclusive(Controls.Stage_Lights, 3)
    elseif flagActive(9)  then setExclusive(Controls.Stage_Lights, 2)
    else                       setExclusive(Controls.Stage_Lights, 1) end

    -- Curtain: flags 11=Close, 12=Open
    if     flagActive(12) then setExclusive(Controls.Curtain, 3)
    elseif flagActive(11) then setExclusive(Controls.Curtain, 2)
    else                       setExclusive(Controls.Curtain, 1) end

    -- Masking: flags 13=Flat, 14=Scope, 15=Special
    if     flagActive(15) then setExclusive(Controls.Masking, 4)
    elseif flagActive(14) then setExclusive(Controls.Masking, 3)
    elseif flagActive(13) then setExclusive(Controls.Masking, 2)
    else                       setExclusive(Controls.Masking, 1) end

    -- Lens: flags 16=Flat, 17=Scope, 18=Special
    if     flagActive(18) then setExclusive(Controls.Lens, 4)
    elseif flagActive(17) then setExclusive(Controls.Lens, 3)
    elseif flagActive(16) then setExclusive(Controls.Lens, 2)
    else                       setExclusive(Controls.Lens, 1) end

    -- Sound: flags 20=Aux1, 21=Aux2, 22=Dig1, 23=Dig2, 24=Mono,
    --        26=NonSync, 27=SR, 28=SVA  (25=Mute handled separately)
    if     flagActive(28) then setExclusive(Controls.Sound, 9)
    elseif flagActive(27) then setExclusive(Controls.Sound, 8)
    elseif flagActive(26) then setExclusive(Controls.Sound, 7)
    elseif flagActive(24) then setExclusive(Controls.Sound, 6)
    elseif flagActive(23) then setExclusive(Controls.Sound, 5)
    elseif flagActive(22) then setExclusive(Controls.Sound, 4)
    elseif flagActive(21) then setExclusive(Controls.Sound, 3)
    elseif flagActive(20) then setExclusive(Controls.Sound, 2)
    else                       setExclusive(Controls.Sound, 1) end

    -- Aux Outputs 1-16: flags 29-44
    for i = 1, 16 do
      Controls.Aux_Out[i].Boolean = flagActive(28 + i)
    end

    -- Digital Projectors and Slide Projector: flags 1-4 and 19
    -- These are also set by RST polling but scrape keeps them in sync
    Controls.Dig1_Power.Boolean    = flagActive(1)
    Controls.Dig1_Video.Boolean    = flagActive(2)
    Controls.Dig2_Power.Boolean    = flagActive(3)
    Controls.Dig2_Video.Boolean    = flagActive(4)
    Controls.Aux_Projector.Boolean = flagActive(19)
  end

  -- HTTP socket handler: accumulates response, parses on close
  httpSock.EventHandler = function(sock, evt, err)
    if evt == TcpSocket.Events.Connected then
      httpConnected = true
      httpBuf = ""
      httpRequest()
    elseif evt == TcpSocket.Events.Data then
      httpBuf = httpBuf .. sock:Read(sock.BufferLength)
    elseif evt == TcpSocket.Events.Closed
        or evt == TcpSocket.Events.Reconnect
        or evt == TcpSocket.Events.Error then
      httpConnected = false
      -- Parse buffered response on connection close
      if #httpBuf > 0 then
        local bodyStart = httpBuf:find("\r\n\r\n")
        if not bodyStart then bodyStart = httpBuf:find("\n\n") end
        if bodyStart then
          local body = httpBuf:sub(bodyStart + 4)
          local ok, serr = pcall(scrape, body)
          if not ok then Controls.Last_Error.String = "Scrape parse: "..(serr or "") end
        end
        httpBuf = ""
      end
      -- Schedule reconnect for next scrape cycle
      if isConnected then httpReconnTmr:Start(0.5) end
    end
  end

  -- Reconnect HTTP socket after 0.5s delay
  httpReconnTmr.EventHandler = function()
    httpReconnTmr:Stop()
    local ip = Controls.IP_ADDRESS.String
    if httpSock and isConnected and isValidIP(ip) then
      httpSock:Connect(ip, 80)
    end
  end

  -- Scrape timer: triggers HTTP request at SCRAPE_RATE interval
  scrapeTimer.EventHandler = function()
    local ok, err = pcall(httpRequest)
    if not ok then Controls.Last_Error.String = "Scrape error: "..(err or "") end
  end

  -- ── Startup ─────────────────────────────────────────────────
  -- Initialise legends, set defaults, start timers, connect
  Controls.Set_Program.Choices = {'1','2','3','4','5','6','7','8','9'}
  if Controls.TCP_PORT.String == "" then
    Controls.TCP_PORT.String = tostring(TCP_PORT)
  end
  for idx, name in ipairs(OutFlagNames) do
    if Controls.Outputs[idx] then Controls.Outputs[idx].Legend = name end
  end
  for idx, name in ipairs(InFlagNames) do
    if Controls.Inputs[idx] then Controls.Inputs[idx].Legend = name end
  end
  if Controls.Macros then
    -- Macro button legends intentionally not set (text labels above buttons used instead)
  end
  -- Aux_Out button legends intentionally not set (text labels above buttons used instead)
  pollTimer:Start(POLL_RATE)
  scrapeTimer:Start(SCRAPE_RATE)
  connect()
  local ip = Controls.IP_ADDRESS.String
  if httpSock and isValidIP(ip) then httpSock:Connect(ip, 80) end
  dbg("Plugin started. port=" .. TCP_PORT)

end  -- if Controls